	<ProjectExtensions>
		<VisualStudio>
			<UserProperties
				manifest_1json__JsonSchema="manifest.schema.json"
				config_1json__JsonSchema="config.schema.json" />
		</VisualStudio>
	</ProjectExtensions>

	<ItemGroup Condition=" '$(ProjectDir)' != '*Undefined*' ">
		<AssetBundles Include="$(ProjectDir)..\$(UnityProjectName)\AssetBundles\**\*" Exclude="**\AssetBundles;**\AssetBundles.manifest" />
	</ItemGroup>

	<!-- Coppies data for next use special settings in Unity project the DLLs are specified in manifest file. -->
	<Target Name="CopyDllsToUnityProject" AfterTargets="PostBuildEvent" Condition=" '$(ProjectDir)' != '*Undefined*' ">
		<Copy SourceFiles="$(TargetPath)" DestinationFolder="$(ProjectDir)..\$(UnityProjectName)\Assets\Dlls\" />
		<Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFolder="$(ProjectDir)..\$(UnityProjectName)\Assets\Dlls\" />
		<Copy SourceFiles="$(TargetDir)$(TargetName).xml" DestinationFolder="$(ProjectDir)..\$(UnityProjectName)\Assets\Dlls\" Condition="$(Configuration)==Release" />
	</Target>

	<!-- Coppies data to mod release folder. For skipping the part, comment out the full target element -->
	<Target Name="DeployToModsFolder" AfterTargets="PostBuildEvent" Condition=" '$(DeployToModsFolder)' == 'true' AND '$(ProjectDir)' != '*Undefined*' ">
		<Copy SourceFiles="$(ProjectDir)\manifest.json" DestinationFolder="$(COI_MODS)\$(TargetName)\" />
		<Copy SourceFiles="$(ProjectDir)\config.json" DestinationFolder="$(COI_MODS)\$(TargetName)" ContinueOnError="true" />
		<Copy SourceFiles="$(ProjectDir)\readme.txt" DestinationFolder="$(COI_MODS)\$(TargetName)" ContinueOnError="true" />
		<Copy SourceFiles="$(TargetPath)" DestinationFolder="$(COI_MODS)\$(TargetName)\" />
		<Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFolder="$(COI_MODS)\$(TargetName)\" Condition="'$(Configuration)' == 'Debug'" />
		<Copy SourceFiles="@(AssetBundles)" DestinationFolder="$(COI_MODS)\$(TargetName)\AssetBundles" />
		<ZipDirectory 
        SourceDirectory="$(COI_MODS)\$(TargetName)" 
        DestinationFile="$(COI_MODS)\$(TargetName)_$(ManifestVersion).zip" 
        Overwrite="true" />
	</Target>
</Project>